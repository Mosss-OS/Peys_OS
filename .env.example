# ============================================
# FRONTEND ENVIRONMENT VARIABLES (.env)
# These are used by the React/Vite frontend
# ============================================

# Supabase Configuration (REQUIRED for email notifications)
# Get these from your Supabase project dashboard: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Privy Configuration (REQUIRED for authentication)
# Get from: https://dashboard.privy.io
VITE_PRIVY_APP_ID=your_privy_app_id

# Polkadot Asset Hub Testnet (Chain ID 420420421)
VITE_RPC_URL_POLKADOT=https://eth-asset-hub-paseo.dotters.network
VITE_ESCROW_CONTRACT_ADDRESS_POLKADOT=0xYOUR_POLKADOT_ESCROW_ADDRESS
VITE_USDC_ADDRESS_POLKADOT=0xYOUR_POLKADOT_USDC_ADDRESS
VITE_USDT_ADDRESS_POLKADOT=0xYOUR_POLKADOT_USDT_ADDRESS

# Celo Alfajores Testnet (Chain ID 44787)
VITE_RPC_URL_CELO=https://alfajores-forno.celo-testnet.org
VITE_ESCROW_CONTRACT_ADDRESS_CELO=0xYOUR_CELO_ESCROW_ADDRESS
VITE_USDC_ADDRESS_CELO=0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B
VITE_USDT_ADDRESS_CELO=0xYOUR_CELO_USDT_ADDRESS
VITE_GDOLLAR_ADDRESS_CELO=0x03d3daB843e6c03b3d271eff9178e6A96c28D25f
VITE_GDOLLAR_IDENTITY_ADDRESS=0x6dB189E677EEaB0833C6693DFeaa979e37447eee

# Base Sepolia Testnet (Chain ID 84532)
VITE_RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
VITE_ESCROW_CONTRACT_ADDRESS_BASE_SEPOLIA=0xYOUR_BASE_SEPOLIA_ESCROW_ADDRESS
VITE_USDC_ADDRESS_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
VITE_USDT_ADDRESS_BASE_SEPOLIA=0xYOUR_BASE_SEPOLIA_USDT_ADDRESS
VITE_GDOLLAR_ADDRESS_BASE_SEPOLIA=0xYOUR_BASE_SEPOLIA_GD_ADDRESS

# Celo Mainnet (Chain ID 42220) - Placeholder
VITE_RPC_URL_CELO_MAINNET=https://forno.celo.org
VITE_ESCROW_CONTRACT_ADDRESS_CELO_MAINNET=0x0000000000000000000000000000000000000001
VITE_USDC_ADDRESS_CELO_MAINNET=0x0000000000000000000000000000000000000002
VITE_USDT_ADDRESS_CELO_MAINNET=0x0000000000000000000000000000000000000003

# Base Mainnet (Chain ID 8453) - Placeholder
VITE_RPC_URL_BASE_MAINNET=https://mainnet.base.org
VITE_ESCROW_CONTRACT_ADDRESS_BASE_MAINNET=0x0000000000000000000000000000000000000001
VITE_USDC_ADDRESS_BASE_MAINNET=0x0000000000000000000000000000000000000002
VITE_USDT_ADDRESS_BASE_MAINNET=0x0000000000000000000000000000000000000003

# Private Keys for Deployment (Backend only - never expose in frontend)
PRIVATE_KEY_POLKADOT=your_polkadot_private_key
PRIVATE_KEY_CELO=your_celo_private_key
PRIVATE_KEY_BASE=your_base_private_key


# ============================================
# BACKEND ENVIRONMENT VARIABLES (Supabase Secrets)
# These are set in your Supabase dashboard: Settings > Edge Functions > Secrets
# Set via CLI: supabase secrets set KEY=value
# ============================================

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Service (REQUIRED for email notifications to work)
# Get from: https://resend.com (FREE tier: up to 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxx

# Custom domain (optional - defaults to peys.xyz@gmail.com)
# You need to verify a domain in Resend before using custom from address
# RESEND_FROM_EMAIL=notifications@yourdomain.com


# ============================================
# SETUP INSTRUCTIONS
# ============================================
#
# 1. FRONTEND SETUP:
#    Copy this file to .env and fill in your values
#
# 2. BACKEND SUPABASE SECRETS:
#    Set via CLI: supabase secrets set KEY=value
#
#    Required:
#    supabase secrets set RESEND_API_KEY=re_xxxxxxxxxx
#    supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#
#    G$ (GoodDollar) Token Addresses (for backend Edge Functions):
#    supabase secrets set GDOLLAR_CELO_ALFAJORES=0x03d3daB843e6c03b3d271eff9178e6A96c28D25f
#    supabase secrets set GDOLLAR_CELO_MAINNET=0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
#    supabase secrets set GDOLLAR_BASE_SEPOLIA=0xYOUR_BASE_SEPOLIA_GD_ADDRESS
#    supabase secrets set GDOLLAR_BASE=0xYOUR_BASE_MAINNET_GD_ADDRESS
#
#    Contract Addresses (per chain):
#    supabase secrets set CONTRACT_BASE_SEPOLIA=0xYOUR_ESCROW_ADDRESS
#    supabase secrets set CONTRACT_CELO_ALFAJORES=0xYOUR_CELO_ESCROW_ADDRESS
#
#    USDC Addresses (per chain):
#    supabase secrets set USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
#    supabase secrets set USDC_CELO_ALFAJORES=0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B
#
# 3. DNS/Domain Setup (Optional but recommended):
#    a) Add your domain to Resend
#    b) Configure DNS records as instructed
#    c) Wait for domain verification
#    d) Use custom from address: notifications@yourdomain.com
#
# 4. TEST EMAIL FLOW:
#    a) Start frontend: npm run dev
#    b) Connect wallet and login with Privy
#    c) Go to Send page, enter recipient email
#    d) Amount > 0 USDC/USDT
#    e) Click Send
#    f) Check recipient email for claim notification
#
# ============================================
